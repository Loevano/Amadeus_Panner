{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.amadeus-panner/schema/showfile.schema.json",
  "title": "ART Showfile",
  "type": "object",
  "required": [
    "show_id",
    "name",
    "version",
    "created_at",
    "updated_at",
    "default_scene_id",
    "scenes",
    "actions"
  ],
  "properties": {
    "show_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "default_scene_id": {
      "type": "string"
    },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scene_id", "file"],
        "properties": {
          "scene_id": { "type": "string" },
          "file": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action_id", "file"],
        "properties": {
          "action_id": { "type": "string" },
          "file": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
