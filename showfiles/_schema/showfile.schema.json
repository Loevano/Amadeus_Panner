{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.amadeus-panner/schema/showfile.schema.json",
  "title": "ART Showfile",
  "type": "object",
  "required": [
    "show_id",
    "name",
    "version",
    "created_at",
    "updated_at",
    "default_scene_id",
    "scenes",
    "actions"
  ],
  "properties": {
    "show_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "default_scene_id": {
      "type": "string"
    },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scene_id", "file"],
        "properties": {
          "scene_id": { "type": "string" },
          "file": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action_id", "file"],
        "properties": {
          "action_id": { "type": "string" },
          "file": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "global_lfos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["lfo_id", "wave", "rate_hz", "depth", "offset"],
        "properties": {
          "lfo_id": { "type": "string" },
          "enabled": { "type": "boolean", "default": true },
          "wave": { "type": "string", "enum": ["sine", "triangle", "square", "saw"] },
          "rate_hz": { "type": "number", "minimum": 0 },
          "depth": { "type": "number" },
          "offset": { "type": "number" },
          "phase_deg": { "type": "number" },
          "polarity": { "type": "string", "enum": ["bipolar", "unipolar"] }
        },
        "additionalProperties": false
      }
    },
    "action_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["group_id", "name", "enabled", "entries", "osc_triggers"],
        "properties": {
          "group_id": { "type": "string" },
          "name": { "type": "string" },
          "enabled": { "type": "boolean" },
          "entries": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["entry_type"],
              "properties": {
                "entry_type": { "type": "string", "enum": ["action", "action_start", "action_stop", "action_abort", "lfos_enabled", "action_lfo_enabled"] },
                "action_id": { "type": "string" },
                "lfo_id": { "type": "string" },
                "command": { "type": "string", "enum": ["start", "stop", "abort"] },
                "enabled": { "type": "boolean" }
              },
              "additionalProperties": false
            }
          },
          "osc_triggers": {
            "type": "object",
            "required": ["trigger"],
            "properties": {
              "trigger": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "groups_enabled": {
      "type": "boolean"
    },
    "object_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["group_id", "name", "object_ids", "link_params", "enabled", "color"],
        "properties": {
          "group_id": { "type": "string" },
          "name": { "type": "string" },
          "object_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "link_params": {
            "type": "array",
            "items": { "type": "string" }
          },
          "enabled": { "type": "boolean" },
          "color": {
            "type": "string",
            "pattern": "^#[0-9a-fA-F]{6}$"
          }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
