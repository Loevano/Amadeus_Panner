{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.amadeus-panner/schema/action.schema.json",
  "title": "ART Action",
  "type": "object",
  "required": ["action_id", "name", "duration_ms", "tracks", "osc_triggers"],
  "properties": {
    "action_id": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "enabled": { "type": "boolean", "default": true },
    "duration_ms": { "type": "integer", "minimum": 0 },
    "on_end_action_id": { "type": "string" },
    "tracks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["object_id", "parameter", "keyframes"],
        "properties": {
          "object_id": { "type": "string" },
          "parameter": { "type": "string" },
          "keyframes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["time_ms", "value"],
              "properties": {
                "time_ms": { "type": "integer", "minimum": 0 },
                "value": { "type": ["number", "boolean", "string"] },
                "curve": { "type": "string", "enum": ["step", "linear", "ease-in", "ease-out"] }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "lfos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["object_id", "parameter", "wave", "rate_hz", "depth", "offset", "phase_deg"],
        "properties": {
          "object_id": { "type": "string" },
          "parameter": { "type": "string", "enum": ["x", "y", "z", "size", "gain"] },
          "wave": { "type": "string", "enum": ["sine", "triangle", "square", "saw"] },
          "rate_hz": { "type": "number", "minimum": 0 },
          "depth": { "type": "number" },
          "offset": { "type": "number" },
          "phase_deg": { "type": "number" }
        },
        "additionalProperties": false
      }
    },
    "osc_triggers": {
      "type": "object",
      "required": ["start", "stop", "abort"],
      "properties": {
        "start": { "type": "string" },
        "stop": { "type": "string" },
        "abort": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
